{% extends "base.twig" %}

{% block title %} Register - SiteGenial {% endblock %}

{% block content %}
<div class="row justify-content-center mt-5">
    <div class="col-md-4">
        <div class="card bg-dark border-secondary shadow-sm">
            <div class="card-body">
                <h3 class="card-title text-center mb-4 text-primary">Creează Cont Nou</h3>

                {% if error %}
                    <div class="alert alert-danger">{{ error }}</div>
                {% endif %}

                <form action="../register.php" method="POST">
                    <div class="mb-3">
                        <label for="username" class="form-label text-light">Username</label>
                        <input type="text" name="username" id="username" class="form-control bg-dark text-light border-secondary" required>
                    </div>
                    <div class="mb-3">
                        <label for="password" class="form-label text-light">Parolă</label>
                        <input type="password" name="password" id="password" class="form-control bg-dark text-light border-secondary" required>
                    </div>
                    <div class="mb-3">
                        <label for="confirm_password" class="form-label text-light">Confirmă Parola</label>
                        <input type="password" name="confirm_password" id="confirm_password" class="form-control bg-dark text-light border-secondary" required>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Înregistrare</button>
                </form>
                
                <div class="mt-3 text-center">
                    <p class="text-muted">Ai deja cont? <a href="../login.php" class="text-info">Loghează-te aici</a></p>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
