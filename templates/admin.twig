{% extends "base.twig" %}

{% block title %} {{ page_title }} {% endblock %}

{% block content %}
    <div class="row mb-4">
        <div class="col">
            <h2 class="text-danger">Admin Panel</h2>
            <p class="text-muted">Gestionare utilizatori și conținut personal.</p>
        </div>
    </div>

    {% if status == 'user_deleted' %}
        <div class="alert alert-success">Utilizator șters cu succes!</div>
    {% elseif status == 'user_added' %}
        <div class="alert alert-success">Utilizator adăugat cu succes!</div>
    {% endif %}

    <!-- Nav tabs -->
    <ul class="nav nav-tabs mb-4" id="adminTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="user-mgmt-tab" data-bs-toggle="tab" data-bs-target="#user-mgmt" type="button" role="tab">Gestionare Utilizatori</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="admin-content-tab" data-bs-toggle="tab" data-bs-target="#admin-content" type="button" role="tab">Conținutul Meu (Admin)</button>
        </li>
    </ul>

    <!-- Tab panes -->
    <div class="tab-content" id="adminTabsContent">
        <!-- User Management Tab -->
        <div class="tab-pane fade show active" id="user-mgmt" role="tabpanel">
            <div class="card bg-dark border-secondary mb-4">
                <div class="card-header border-secondary text-light">Adaugă Utilizator Nou</div>
                <div class="card-body">
                    <form action="admin.php" method="POST" class="row g-3">
                        <div class="col-md-4">
                            <input type="text" name="username" class="form-control bg-dark border-secondary text-light" placeholder="Username" required>
                        </div>
                        <div class="col-md-4">
                            <input type="password" name="password" class="form-control bg-dark border-secondary text-light" placeholder="Parolă" required>
                        </div>
                        <div class="col-md-2">
                            <select name="role" class="form-select bg-dark border-secondary text-light">
                                <option value="normal_user">Normal User</option>
                                <option value="admin">Admin</option>
                            </select>
                        </div>
                        <div class="col-md-2">
                            <button type="submit" name="add_user" class="btn btn-primary w-100">Adaugă</button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-dark table-hover border-secondary">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Username</th>
                            <th>Rol</th>
                            <th>Acțiuni</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for user in users %}
                            <tr>
                                <td>{{ user.id }}</td>
                                <td>{{ user.username }}</td>
                                <td>
                                    {% if user.role == 'admin' %}
                                        <span class="badge bg-danger">Admin</span>
                                    {% else %}
                                        <span class="badge bg-secondary">User</span>
                                    {% endif %}
                                </td>
                                <td>
                                    {% if user.id != session.user_id and user.role != 'admin' %}
                                        <a href="admin.php?delete_user_id={{ user.id }}" class="btn btn-sm btn-danger" onclick="return confirm('Sigur vrei să ștergi acest utilizator?')">Șterge</a>
                                    {% endif %}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Admin Content Tab (Articles & Galleries) -->
        <div class="tab-pane fade" id="admin-content" role="tabpanel">
             <div class="row g-4">
                <div class="col-md-6">
                    <h4 class="text-info mb-3">Galeriile Mele</h4>
                    <div class="list-group">
                        {% for gallery in galleries %}
                            <div class="list-group-item bg-dark border-secondary text-light d-flex justify-content-between align-items-center">
                                {{ gallery.name }}
                                <div>
                                    <a href="../gallery.php?galleryId={{ gallery.id }}" class="btn btn-sm btn-outline-info">Vezi</a>
                                    <button class="btn btn-sm btn-outline-danger">Șterge</button>
                                </div>
                            </div>
                        {% else %}
                             <p class="text-muted">Nu ai galerii.</p>
                        {% endfor %}
                    </div>
                </div>
                <div class="col-md-6">
                    <h4 class="text-info mb-3">Articolele Mele</h4>
                    <div class="list-group">
                        {% for article in articles %}
                            <div class="list-group-item bg-dark border-secondary text-light d-flex justify-content-between align-items-center">
                                {{ article.title }}
                                <div>
                                    <button class="btn btn-sm btn-outline-info">Vezi</button>
                                    <button class="btn btn-sm btn-outline-danger">Șterge</button>
                                </div>
                            </div>
                        {% else %}
                            <p class="text-muted">Nu ai articole.</p>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
