{% extends "base.twig" %}

{% block title %} Home - {{ page_title }}{% endblock %}

{% block content %}
    <div class="p-5 mb-5 bg-dark border border-secondary text-light rounded-3 shadow-sm">
        <h1 class="display-5 fw-bold text-primary">Bine ai venit la SiteGenial!</h1>
        <p class="col-md-8 fs-5 text-muted">Explorează galerii foto și articole interesante de la comunitatea noastră.</p>
    </div>

    <!-- Nav tabs -->
    <ul class="nav nav-pills mb-4" id="contentTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="galleries-tab" data-bs-toggle="pill" data-bs-target="#galleries" type="button" role="tab">Galerii</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="articles-tab" data-bs-toggle="pill" data-bs-target="#articles" type="button" role="tab">Articole</button>
        </li>
    </ul>

    <!-- Tab panes -->
    <div class="tab-content" id="contentTabsContent">
        <!-- Galleries Tab -->
        <div class="tab-pane fade show active" id="galleries" role="tabpanel">
            <div class="row g-4">
                {% for gallery in galleries %}
                    <div class="col-lg-4 col-md-6">
                        <div class="card h-100 d-flex flex-column shadow-sm bg-dark border-secondary">
                            <div class="card-body d-flex flex-column flex-grow-1">
                                <h5 class="card-title text-light fw-bold">{{ gallery.name }}</h5>
                                <div class="p-0 mb-2 small text-info">De la autorul: {{ gallery.author_name }}</div>
                                <a href="../gallery.php?galleryId={{ gallery.id }}" class="btn btn-outline-primary w-100 mt-auto">
                                    Explorează Galeria
                                </a>
                            </div>
                        </div>
                    </div>
                {% else %}
                    <div class="col-12">
                        <div class="alert alert-info bg-dark border-secondary text-light">Nu s-au găsit galerii momentan.</div>
                    </div>
                {% endfor %}
            </div>
        </div>

        <!-- Articles Tab -->
        <div class="tab-pane fade" id="articles" role="tabpanel">
            <div class="row g-4">
                {% for article in articles %}
                    <div class="col-12">
                        <div class="card shadow-sm bg-dark border-secondary mb-3">
                            <div class="card-body">
                                <h5 class="card-title text-light fw-bold">{{ article.title }}</h5>
                                <h6 class="card-subtitle mb-2 text-info">Scris de: {{ article.author_name }}</h6>
                                <div class="card-text text-muted">
                                    {% set preview = article.content|slice(0, 200) %}
                                    {% for paragraph in preview|split('\n') %}
                                        {% if paragraph|trim is not empty %}
                                            <p class="mb-1">{{ paragraph|trim }}{{ loop.last and article.content|length > 200 ? '...' : '' }}</p>
                                        {% endif %}
                                    {% endfor %}
                                </div>
                                <a href="../article.php?articleId={{ article.id }}" class="btn btn-outline-info btn-sm">Citește mai mult</a>
                            </div>
                        </div>
                    </div>
                {% else %}
                    <div class="col-12">
                        <div class="alert alert-info bg-dark border-secondary text-light">Nu s-au găsit articole momentan.</div>
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>
{% endblock %}