{% extends "base.twig" %}

{% block title %}{{ page_title }}{% endblock %}

{% block content %}
    <div class="row">
        <div class="col-lg-8 mx-auto">
            <div class="card bg-dark border-secondary shadow-sm">
                <div class="card-header border-secondary">
                    <h3 class="text-primary mb-0">{{ is_edit ? 'Editează Articol' : 'Scrie Articol Nou' }}</h3>
                </div>
                <div class="card-body">
                    <form action="../edit_article.php{{ is_edit ? '?articleId=' ~ article.id : '' }}" method="POST">
                        <input type="hidden" name="article_id" value="{{ article.id }}">
                        <div class="mb-3">
                            <label for="title" class="form-label text-light">Titlu</label>
                            <input type="text" class="form-control bg-light text-dark border-light" id="title" name="title" value="{{ article.title }}" required>
                        </div>
                        <div class="mb-3">
                            <label for="content" class="form-label text-light">Conținut</label>
                            <textarea class="form-control bg-light text-dark border-light" id="content" name="content" rows="15" required>{{ article.content }}</textarea>
                        </div>
                        <div class="d-flex justify-content-between">
                            <a href="../my_content.php" class="btn btn-outline-secondary">Anulează</a>
                            <button type="submit" class="btn btn-primary">{{ is_edit ? 'Salvează Modificările' : 'Publică Articolul' }}</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
